# Required for the /admin section.
# In Vercel, set these under Settings -> Environment Variables.
# Locally, copy this file to .env.local and fill in real values.

# Password for /admin/login. Pick something long.
ADMIN_PASSWORD=

# HMAC key for the admin session cookie. Must be >= 32 chars.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# Cloudflare API token with Zone.DNS:Read permission.
# Create at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Zone ID of the domain to list DNS records for.
# Find in Cloudflare dashboard -> your domain -> Overview (bottom-right sidebar).
CLOUDFLARE_ZONE_ID=
