{
  "name": "leetcode-notes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "npm-run-all --parallel dev convex",
    "convex": "node node_modules/convex/bin/main.js dev",
    "build": "node node_modules/convex/bin/main.js deploy --cmd \"next build\" --cmd-url-env-var-name NEXT_PUBLIC_CONVEX_URL",
    "build:next": "next build",
    "start": "next start",
    "lint": "next lint",
    "predev": "node scripts/ensure-convex-codegen.mjs"
  },
  "dependencies": {
    "@micahtid/ui": "workspace:*",
    "convex": "^1.17.4",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0-beta.6",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "npm-run-all2": "^7.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0-beta.6",
    "typescript": "^5"
  }
}
