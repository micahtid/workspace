{
  "name": "workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:portfolio": "pnpm --filter portfolio dev",
